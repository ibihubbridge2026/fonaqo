# ===========================================
# FONAQO - Configuration des Variables d'Environnement
# ===========================================
# Copiez ce fichier en .env et remplissez les valeurs appropriées
# Ne commitez JAMAIS le fichier .env dans Git
# ===========================================

# ===========================================
# 🔌 API BACKEND
# ===========================================
# URL du serveur backend Django
# - Émulateur Android: http://10.0.2.2:8000
# - Device physique (même réseau): http://<IP_LOCALE>:8000
# - Production: https://api.fonaqo.com

SERVER_URL=http://10.0.2.2:8000
API_BASE_URL=http://10.0.2.2:8000/api/v1/

# ===========================================
# 🔐 SÉCURITÉ & JWT
# ===========================================
# Clés de chiffrement pour flutter_secure_storage
# Générer des valeurs aléatoires pour la production
ANDROID_ENCRYPTED_PREFS_NAME=secure_storage_fonaqo
IOS_ACCESS_GROUP=com.fonaqo.secure

# ===========================================
# 📱 FIREBASE
# ===========================================
# IDs de projet Firebase pour les notifications push
FIREBASE_PROJECT_ID=fonaqo-dev
FIREBASE_APP_ID_ANDROID=1:123456789:android:abcdef123456
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ===========================================
# 🗺️ GOOGLE MAPS
# ===========================================
# Clé API Google Maps pour la géolocalisation
GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ===========================================
# 💳 PAIEMENT (Mobile Money)
# ===========================================
# Configuration MTN Mobile Money (MoMo)
MTN_MOMO_API_KEY=votre_clé_mtn_momo
MTN_MOMO_SUBSCRIPTION_KEY=votre_subscription_key
MTN_MOMO_ENVIRONMENT=sandbox  # sandbox ou production

# Configuration Moov Money (Flooz)
MOOV_FLOOZ_API_KEY=votre_clé_moov
MOOV_FLOOZ_MERCHANT_ID=votre_id_marchant
MOOV_FLOOZ_ENVIRONMENT=sandbox  # sandbox ou production

# ===========================================
# 🌍 WEBSOCKETS
# ===========================================
# URL WebSocket pour le chat en temps réel
# Format: ws://host:port ou wss://host:port pour HTTPS
WS_URL=ws://10.0.2.2:8000/ws

# ===========================================
# 📊 ANALYTICS & LOGGING
# ===========================================
# Sentry pour le tracking d'erreurs (optionnel)
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
SENTRY_ENV=development  # development, staging, production

# Firebase Crashlytics (activé via firebase_core)
CRASHLYTICS_ENABLED=true

# ===========================================
# 🔔 NOTIFICATIONS PUSH
# ===========================================
# VAPID keys pour les notifications web (si applicable)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# ===========================================
# 🧪 FEATURES FLAGS
# ===========================================
# Activer/désactiver des fonctionnalités en fonction de l'environnement
ENABLE_AI_SEARCH=true
ENABLE_CHAT=true
ENABLE_WALLET=true
ENABLE_BOOSTS=true
ENABLE_DISPUTES=true

# Mode debug
DEBUG_MODE=true
LOG_HTTP_REQUESTS=true

# ===========================================
# ⚙️ CONFIGURATION APP
# ===========================================
# Version de l'application
APP_VERSION=1.0.0
BUILD_NUMBER=1

# Environment courant
APP_ENV=development  # development, staging, production

# Délais API (en secondes)
API_CONNECT_TIMEOUT=30
API_RECEIVE_TIMEOUT=30
API_SEND_TIMEOUT=30

# ===========================================
# 📦 STORAGE
# ===========================================
# Nom des préférences partagées
SHARED_PREFERENCES_NAME=fonaqo_prefs

# Limites d'upload (en MB)
MAX_FILE_UPLOAD_SIZE_MB=10
MAX_IMAGE_UPLOAD_SIZE_MB=5
