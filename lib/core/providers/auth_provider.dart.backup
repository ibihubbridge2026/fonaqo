import 'package:flutter/material.dart';
import 'package:flutter_secure_storage/flutter_secure_storage.dart';
import 'package:logger/logger.dart';

import '../models/user_model.dart';
import '../api/base_client.dart';

/// Provider pour gérer l'état d'authentification de l'application
/// Utilise ChangeNotifier pour notifier les widgets écoutants des changements
class AuthProvider extends ChangeNotifier {
  final FlutterSecureStorage _secureStorage = const FlutterSecureStorage();
  static const String _tokenKey = 'jwt_token';
  static const String _userKey = 'user_data';
  final Logger _logger = Logger();
  final BaseClient _baseClient = BaseClient();

  bool _isAuthenticated = false;
  bool _isLoading = false;
  String? _errorMessage;
  UserModel? _currentUser;

  /// Getters
  bool get isAuthenticated => _isAuthenticated;
  bool get isLoading => _isLoading;
  String? get errorMessage => _errorMessage;
  UserModel? get currentUser => _currentUser;

  /// Getters pratiques
  bool get isAgent => _currentUser?.isAgent ?? false;
  bool get isClient => _currentUser?.isClient ?? false;
  bool get isVerified => _currentUser?.isVerified ?? false;

  AuthProvider() {
    _loadUserData();
  }

  /// Setters privés
  void _setLoading(bool loading) {
    _isLoading = loading;
    notifyListeners();
  }

  void _setError(String error) {
    _errorMessage = error;
    notifyListeners();
  }

  void _clearError() {
    _errorMessage = null;
    notifyListeners();
  }

  /// Connexion utilisateur
  Future<bool> login(Map<String, dynamic> credentials) async {
    _setLoading(true);
    _clearError();

    try {
      // Appeler l'API de connexion
      final response = await _baseClient.post('/accounts/login/', credentials);
      
      // Logger détaillé pour debug
      _logger.d('Status Code: ${response.statusCode}');
      _logger.i('Data reçue: ${response.data}');

      // Vérifier si la réponse contient les données attendues
      if (response.statusCode != 200) {
        final errorMessage = response.data is Map
            ? response.data['message'] ?? 'Erreur de connexion'
            : 'Erreur de connexion';
        _setError(errorMessage);
        return false;
      }

      final responseData = response.data as Map<String, dynamic>;
      final data = responseData['data'] as Map<String, dynamic>?;
      final accessToken = data?['access_token'] as String?;
      final userData = data?['user'] as Map<String, dynamic>?;

      // Validation stricte des données utilisateur
      if (accessToken == null) {
        _setError('Token manquant dans la réponse du serveur');
        return false;
      }

      if (userData == null) {
        _setError('Données utilisateur manquantes dans la réponse');
        return false;
      }

      try {
        // Logger le token pour vérification
        _logger.i("Token extrait: ${accessToken}");

        // Sauvegarder le token
        await _secureStorage.write(key: _tokenKey, value: accessToken);

        // Créer l'objet UserModel avec try-catch spécifique
        try {
          _logger.d("Données utilisateur reçues: $userData");

          // Vérifier chaque champ individuellement
          final id = userData['id'];
          final email = userData['email'];
          final phoneNumber = userData['phone_number'];
          final username = userData['username'];
          final isAgent = userData['is_agent'];
          final isClient = userData['is_client'];
          final isVerified = userData['is_verified'];

          _logger.d(
            "Types des champs - id: ${id.runtimeType}, email: ${email.runtimeType}, phoneNumber: ${phoneNumber.runtimeType}",
          );
          _logger.d(
            "Types booléens - is_agent: ${isAgent.runtimeType}, is_client: ${isClient.runtimeType}, is_verified: ${isVerified.runtimeType}",
          );

          final user = UserModel.fromJson(userData);
          _currentUser = user;
          _isAuthenticated = true;
          notifyListeners();

          return true;
        } catch (userError) {
          _logger.e(
            'Erreur spécifique lors de la création du UserModel: ${userError.toString()}',
          );
          _logger.e('Détails des données utilisateur: $userData');

          // Identifier le champ problématique
          if (userError.toString().contains('String')) {
            _setError(
              'Erreur de type: un champ attendu comme String est reçu avec un autre type. Détails: ${userError.toString()}',
            );
          } else if (userError.toString().contains('bool')) {
            _setError(
              'Erreur de type: un champ attendu comme bool est reçu avec un autre type. Détails: ${userError.toString()}',
            );
          } else {
            _setError(
              'Erreur lors de la création du profil utilisateur: ${userError.toString()}',
            );
          }
          return false;
        }
      } catch (e) {
        _setError('Erreur inattendue: ${e.toString()}');
        return false;
      }
    } catch (e) {
      _setError('Erreur réseau: ${e.toString()}');
      return false;
    } finally {
      _setLoading(false);
    }
  }

  /// Déconnexion utilisateur
  Future<void> logout() async {
    _setLoading(true);
    try {
      await _secureStorage.delete(key: _tokenKey);
      await _secureStorage.delete(key: _userKey);
      _currentUser = null;
      _isAuthenticated = false;
      notifyListeners();
    } catch (e) {
      _setError('Erreur lors de la déconnexion');
    } finally {
      _setLoading(false);
    }
  }

  /// Chargement des données utilisateur sauvegardées
  Future<void> _loadUserData() async {
    try {
      final token = await _secureStorage.read(key: _tokenKey);
      final userDataString = await _secureStorage.read(key: _userKey);

      if (token != null && userDataString != null) {
        _isAuthenticated = true;
        try {
          final userData = Map<String, dynamic>.from(
            userDataString?.replaceAll(RegExp(r"'(\w+)':\s*"), '"$1": "$2"') ?? {},
          );
          _currentUser = UserModel.fromJson(userData);
        } catch (e) {
          _logger.e('Erreur lors du chargement des données utilisateur: $e');
          _currentUser = null;
          _isAuthenticated = false;
        }
      } else {
        _currentUser = null;
        _isAuthenticated = false;
      }
      notifyListeners();
    } catch (e) {
      _logger.e('Erreur lors du chargement des données utilisateur: $e');
    }
  }

  /// Récupérer les missions disponibles pour les agents
  Future<List<Map<String, dynamic>>> fetchAvailableMissions({double? lat, double? lng}) async {
    _setLoading(true);
    _clearError();

    try {
      // Appeler l'API missions/available
      Map<String, dynamic> queryParams = {};
      if (lat != null && lng != null) {
        queryParams['lat'] = lat.toString();
        queryParams['lng'] = lng.toString();
      }

      final response = await _baseClient.get('/missions/available/', queryParams: queryParams);
      
      if (response.statusCode == 200) {
        final responseData = response.data as Map<String, dynamic>;
        final missionsData = responseData['data'] as List<dynamic>? ?? [];
        _logger.i('Missions disponibles récupérées: ${missionsData.length}');
        return missionsData.cast<Map<String, dynamic>>();
      } else {
        _setError('Erreur lors de la récupération des missions disponibles');
        return [];
      }
    } catch (e) {
      _setError('Erreur réseau: ${e.toString()}');
      return [];
    } finally {
      _setLoading(false);
    }
  }

  /// Méthode de mot de passe oublié
  Future<bool> forgotPassword(String email) async {
    _setLoading(true);
    _clearError();

    try {
      // TODO: Remplacer par l'appel au service de mot de passe oublié
      // Exemple: final response = await authService.forgotPassword(email);
      await Future.delayed(const Duration(seconds: 2));

      // Simuler un email envoyé
      _setError('Un email de réinitialisation a été envoyé à $email');
      return true;
    } catch (e) {
      _setError('Erreur d\'envoi d\'email: ${e.toString()}');
      return false;
    } finally {
      _setLoading(false);
    }
  }

  /// Rafraîchit le token (sera utilisé par l'intercepteur en cas de token expiré)
  Future<bool> refreshToken() async {
    try {
      // TODO: Implémenter le rafraîchissement du token
      // Exemple: final response = await authService.refreshToken();
      await Future.delayed(const Duration(seconds: 2));
      return true;
    } catch (e) {
      _setError('Erreur lors du rafraîchissement du token');
      return false;
    }
  }

  /// Getter pour obtenir le token actuel (utilisé par les services)
  Future<String?> getToken() async {
    return await _secureStorage.read(key: _tokenKey);
  }
}
